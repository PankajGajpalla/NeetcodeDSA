Input: keyboard = "abcdefghijklmnopqrstuvwxyz", word = "cba"

if(word=="") return 0;

vector<int> atoz(26,0);
for(int i=0; i<26; i++){
    atoz[keyboard[i]-'a']=i;
}

total = atoz[word[0]-'a'];
for(int i=1; i<word.length(); i++){
    total += abs(atoz[word[i-1]-'a'] - atoz[word[i]-'a']);
}

return total;  
