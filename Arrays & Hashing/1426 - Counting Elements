1426. Counting Elements

int ans = 0;
for(auto i: arr){
    for(auto j: arr){
        if(i+1==j){
            ans++;
            break;
        }
    }
}

return ans;

int ans = 0;
int repeat = 1;
sort(arr.begin(), arr.end());
for(int i=1; i<arr.size(); i++){
    if(arr[i-1] != arr[i]){
        if(arr[i-1]+1 == arr[i]){
            ans += repeat;
        }
        repeat=0;
    }
    repeat++;
}
return ans;
